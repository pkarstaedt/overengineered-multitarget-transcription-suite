# Copy to .env for local runtime tuning.
#
# The shell scripts load .env automatically. Values exported inline still work:
# POST_EDITOR_MIN_EDIT_CHARS=120 ./run.sh

# Proxy listener
HOST=0.0.0.0
PORT=8010

# Upstream ASR and Ollama
POST_EDITOR_UPSTREAM_URL=http://127.0.0.1:8001/transcribe
POST_EDITOR_OLLAMA_URL=http://127.0.0.1:11434
POST_EDITOR_MODEL=qwen3:1.7b

# Prompt file path, relative to post-editor-proxy/ unless absolute.
POST_EDITOR_PROMPT_FILE=post_editor_prompt.md

# Fast cleanup defaults
POST_EDITOR_THINK=false
POST_EDITOR_MIN_EDIT_CHARS=0
POST_EDITOR_LOG_TEXT=true

# Optional proxy tuning
POST_EDITOR_DISABLE_EDIT=false
POST_EDITOR_NUM_CTX=4096
POST_EDITOR_KEEP_ALIVE=30m
POST_EDITOR_TEMPERATURE=0
POST_EDITOR_TIMEOUT_SECONDS=120
POST_EDITOR_OLLAMA_TIMEOUT_SECONDS=45

# Interactive chat defaults. Chat can reason while the proxy stays fast.
OLLAMA_CHAT_THINK=true
OLLAMA_CHAT_NUM_CTX=4096
OLLAMA_CHAT_TEMPERATURE=0.6
OLLAMA_CHAT_KEEP_ALIVE=30m
