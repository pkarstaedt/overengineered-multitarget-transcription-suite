{
  "transcription_backend": "http",
  "server_url": "http://127.0.0.1:8001/transcribe",
  "openai_transcription_model": "gpt-4o-mini-transcribe",
  "openai_transcription_prompt_markdown_file": "transcription_prompt.md",
  "hotkey": "ctrl+shift+space",
  "fast_hotkey": "",
  "undo_hotkey": "",
  "microphone_index": null,
  "language": null,
  "sample_rate": 16000,
  "pre_type_delay": 0.05,
  "char_delay": 0.0,
  "duck_audio_during_dictation": false,
  "duck_audio_level_percent": 25,
  "erase_delay": 0.08,
  "main_live_mode": false,
  "main_simple_mode": true,
  "main_mode": "preview",
  "main_post_edit_mode": false,
  "fast_live_mode": false,
  "fast_simple_mode": true,
  "fast_mode": "preview",
  "fast_post_edit_mode": false,
  "openai_model": "gpt-5-mini",
  "openai_reasoning_effort": "low",
  "openai_dev_prompt_markdown_file": "dev_post_edit_prompt.md",
  "openai_pro_prompt_markdown_file": "pro_post_edit_prompt.md",
  "openai_personal_prompt_markdown_file": "personal_post_edit_prompt.md",
  "editor_notes_overlay_seconds": 4.0,
  "editor_notes_chars_per_extra_second": 45.0,
  "post_edit_toggle_key": "y",
  "main_review_non_post_edit_sessions": false,
  "fast_review_non_post_edit_sessions": false,
  "preview_max_width": 860,
  "preview_max_height": 1000,
  "vad_silence_rms": 400,
  "vad_silence_secs": 1.5,
  "vad_min_speech_s": 0.5,
  "vad_hangover_s": 0.3,
  "vad_max_chunk_s": 30.0,
  "debug": false,
  "input_classes": [
    "CASCADIA_HOSTING_WINDOW_CLASS",
    "Chrome_RenderWidgetHostHWND",
    "Chrome_WidgetWin_1",
    "ConsoleWindowClass",
    "Edit",
    "MozillaContentWindowClass",
    "MozillaWindowClass",
    "RICHEDIT60W",
    "RichEdit",
    "RichEdit20A",
    "RichEdit20W",
    "RichEdit50W",
    "Scintilla",
    "TListBox",
    "WebViewWnd"
  ],
  "type_input_classes": [
    "CASCADIA_HOSTING_WINDOW_CLASS",
    "ConsoleWindowClass"
  ],
  "right_click_paste_input_classes": [
    "TListBox"
  ],
  "simple_mode_input_classes": [
    "CASCADIA_HOSTING_WINDOW_CLASS",
    "ConsoleWindowClass",
    "TListBox"
  ],
  "live_mode_input_classes": []
}
